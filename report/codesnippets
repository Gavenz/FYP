    if phase == "heapify":
        arr, active, secondary = next_heapify_step()
        return state("heapify", arr, active, secondary)

    elif phase == "insert":
        arr, active, secondary = next_insert_step()
        return state("insert", arr, active, secondary)

    elif phase == "delete":
        arr, active, secondary = next_delete_step()
        return state("delete", arr, active, secondary)

    elif phase == "place_word":
        word, position = choose_best_placement()
        place_word_on_grid(word, position)
        return state("placement", grid)

    elif phase == "fill":
        fill_remaining_cells()
        return state("done", grid)
    

def step(self):
    if self.mode == "seek_start":
        r, c = self.starts.pop(0)
        ch = self.grid[r][c]

        if self.trie.has_prefix(ch):
            self._push(r, c)
            self.mode = "dfs"
            return state("explore", path=self.path, prefix=self.pref)

    if self.mode == "dfs":
        if self.trie.is_word(self.pref):
            return state("found_word", word=self.pref, path=self.path)

        for rr, cc in neighbors_of_top():
            candidate = self.pref + self.grid[rr][cc]

            if self.trie.has_prefix(candidate) is None:
                return state("reject", prefix=candidate, probe=(rr, cc))

            self._push(rr, cc)
            return state("explore", path=self.path, prefix=self.pref)

        self._pop()
        return state("backtrack", path=self.path, prefix=self.pref)